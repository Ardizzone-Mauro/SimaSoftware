@model SIMA_SOFTWARE.Models.Cliente

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container mt-4">

    <div class="mb-4">
        <h2 class="text-white">Eliminar Cliente</h2>
        <p class="text-muted">Confirmar eliminación</p>
    </div>

    <div class="card shadow-lg border-0">
        <div class="card-body">

            <div class="alert alert-danger">
                ⚠️ Esta acción no se puede deshacer
            </div>

            <form asp-action="Delete">

                <input type="hidden" asp-for="IdCliente" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" value="@Model.Nombre" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" value="@Model.Email" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input class="form-control" value="@Model.Telefono" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Dirección</label>
                        <input class="form-control"
                               value="@Model.Direccion?.Barrio - @Model.Direccion?.Calle @Model.Direccion?.NroPuerta"
                               readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo Cliente</label>
                        <input class="form-control" value="@Model.TipoCliente?.Categoria" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Saldo</label>
                        <input class="form-control" value="$ @Model.Cuenta?.Saldo" readonly />
                    </div>

                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">← Cancelar</a>
                    <button type="submit" class="btn btn-danger">🗑️ Eliminar</button>
                </div>

            </form>

        </div>
    </div>
</div>
