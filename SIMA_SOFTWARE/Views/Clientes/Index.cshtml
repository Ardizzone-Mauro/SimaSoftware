@model List<SIMA_SOFTWARE.Models.Cliente>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<main class="main-content">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Clientes</h2>
        <a asp-action="Create" class="btn btn-success">
            + Nuevo Cliente
        </a>
    </div>
    <a asp-action="Index" asp-route-activos="true" class="btn btn-success">Activos</a>
    <a asp-action="Index" asp-route-activos="false" class="btn btn-danger">Inactivos</a>
    <a asp-action="Index" class="btn btn-secondary">Todos</a>

    <!-- CARD -->
    <div class="card shadow-lg border-0">
        <div class="card-body">

            <div class="table-responsive">
                <table id="clientesTable" class="table table-dark table-hover align-middle text-white table-custom">

                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th>Dirección</th>
                            <th>Tipo</th>
                            <th>Saldo</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Nombre</td>
                                <td>@item.Email</td>
                                <td>@item.Telefono</td>

                                <td>
                                    @item.Direccion?.Barrio - @item.Direccion?.Calle @item.Direccion?.NroPuerta
                                </td>

                                <td>
                                    <span class="badge bg-primary">
                                        @item.TipoCliente?.Categoria
                                    </span>
                                </td>

                                <td>
                                    $ @item.Cuenta?.Saldo
                                </td>

                                <td>
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.IdCliente" class="btn btn-sm btn-info">Ver</a>
                                    <a asp-action="Edit" asp-route-id="@item.IdCliente" class="btn btn-sm btn-warning">Editar</a>
                                    @if (item.Activo)
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.IdCliente" class="btn btn-sm  btn-danger ">
                                            Desactivar
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="Activar" asp-route-id="@item.IdCliente" class="btn btn-sm w-auto btn-success ">
                                            Activar
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>



@section Scripts {
    <!-- Scripts para DataTables cargados desde el layout; aquí solo por si quieres scripts específicos de esta vista -->
}
</main>