@model SIMA_SOFTWARE.Models.ViewModels.DashboardViewModel


@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- Main Content -->
<main class="main-content">

    <header class="mb-5">
        <h1 class="fw-black text-light mb-1">Panel de Control</h1>
        <p class="text-secondary mb-0">Bienvenido de nuevo, esto es lo que está sucediendo en SIMA hoy.</p>
    </header>
    <!-- Metric Cards -->
    <div class="row g-4 mb-5">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="custom-card">
                <span class="material-symbols-outlined metric-icon-bg">group</span>
                <p class="text-uppercase small fw-bold text-secondary mb-1" style="font-size: 10px;">Total Clientes</p>
                <h3 class="fw-black text-white mb-2">
                    @Model.TotalClientes
                </h3>

                <div class="d-flex align-items-center gap-1 text-success small fw-bold">
                    <span class="material-symbols-outlined fs-6">trending_up</span>
                    Datos en tiempo real
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="custom-card">
                <span class="material-symbols-outlined metric-icon-bg">shopping_bag</span>
                <p class="text-uppercase small fw-bold text-secondary mb-1" style="font-size: 10px;">Pedidos Activos</p>
                <h3 class="fw-black text-white mb-2">
                    @Model.PedidosActivos
                </h3>

                <div class="d-flex align-items-center gap-1 text-success small fw-bold">
                    <span class="material-symbols-outlined fs-6">arrow_forward</span>
                    @Model.PedidosFacturados Pedidos Facturados
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="custom-card">
                <span class="material-symbols-outlined metric-icon-bg">inventory</span>
                <p class="text-uppercase small fw-bold text-secondary mb-1" style="font-size: 10px;">Stock Total</p>
                <h3 class="fw-black text-white mb-2">
                    @Model.StockTotal
                </h3>

                <div class="d-flex align-items-center gap-1 text-warning small fw-bold">
                    <span class="material-symbols-outlined fs-6">warning</span>
                    @Model.StockBajo bajo mínimos
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="custom-card">
                <span class="material-symbols-outlined metric-icon-bg">payments</span>
                <p class="text-uppercase small fw-bold text-secondary mb-1" style="font-size: 10px;">Ingresos Mensuales</p>
                <h3 class="fw-black text-white mb-2">
                    $@Model.IngresosMensuales.ToString("N0")
                </h3>

                <div class="d-flex align-items-center gap-1
    @(Model.VariacionIngresos >= 0 ? "text-success" : "text-danger")
    small fw-bold">

                    <span class="material-symbols-outlined fs-6">
                        @(Model.VariacionIngresos >= 0 ? "trending_up" : "trending_down")
                    </span>

                    @Model.VariacionIngresos.ToString("0.##")% vs mes anterior
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4">
        <!-- Table Section -->
        <div class="col-12 col-lg-8">
            <div class="custom-card p-0 border-0 shadow-lg" style="background-color: var(--surface-bg);">
                <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-success rounded-pill" style="width: 4px; height: 24px;"></div>
                        <h2 class="h5 fw-bold mb-0 text-white">Pedidos Recientes</h2>
                    </div>
                    <a asp-controller="Pedido"
                       asp-action="Index"
                       class="btn btn-link text-success text-decoration-none fw-bold small p-0">

                        Ver todos

                    </a>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Cliente</th>
                                <th>Estado</th>
                                <th>Total</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        
                        <tbody>
                            @foreach (var item in Model.PedidosRecientes)
                            {
                                <tr>
                                    <!-- ID -->
                                    <td class="text-secondary fw-medium">
                                        #ORD-@item.IdPedido
                                    </td>

                                    <!-- CLIENTE -->
                                    <td>
                                        <div class="d-flex align-items-center gap-2">

                                            <!-- Iniciales -->
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width: 28px; height: 28px; font-size: 10px;">

                                                @(item.ClienteNombre != null
                                                                                            ? item.ClienteNombre.Substring(0, 2).ToUpper()
                                                                                            : "NA")
                                        </div>

                                            <span class="fw-semibold text-light">
                                                @item.ClienteNombre
                                            </span>
                                        </div>
                                    </td>

                                    <!-- ESTADO -->
                                    <td>
                                    @if (item.Estado == "Pendiente")
                                        {
                                            <span class="badge-status bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25">
                                                Pendiente
                                            </span>
                                        }
                                        else if (item.Estado == "En Proceso")
                                        {
                                            <span class="badge-status bg-info bg-opacity-10 text-info border border-info border-opacity-25">
                                                En Proceso
                                            </span>
                                        }
                                        else if (item.Estado == "Facturado")
                                        {
                                            <span class="badge-status bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                                Facturado
                                            </span>
                                        }
                                        else if (item.Estado == "Cancelado")
                                        {
                                            <span class="badge-status bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">
                                                Cancelado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge-status bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
                                                @item.Estado
                                            </span>
                                        }
                                    </td>

                                    <!-- TOTAL -->
                                    <td class="fw-bold text-light">
                                        $@item.Total.ToString("N2")
                                    </td>

                                    <!-- FECHA -->
                                    <td class="text-secondary">
                                        @item.Fecha.ToString("dd/MM/yyyy")
                                    </td>

                                   

                                </tr>
                            }
                        
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- Side Panels -->
        <div class="col-12 col-lg-4">
            <div class="d-flex flex-column gap-4">
                <!-- Stock Alerts -->
                <div class="custom-card">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="bg-warning rounded-pill" style="width: 4px; height: 24px;"></div>
                        <h2 class="h5 fw-bold mb-0 text-white">Alertas de Stock</h2>
                    </div>
                    <div class="vstack gap-3">

                        @if (Model.ProductosStockBajo.Any())
                        {
                            @foreach (var item in Model.ProductosStockBajo)
                            {
                                <div class="d-flex align-items-center justify-content-between p-2 rounded-3 bg-dark bg-opacity-25">

                                    <div class="d-flex align-items-center gap-3">

                                        <!-- Icono -->
                                        @if (!string.IsNullOrEmpty(item.Producto?.UrlImagen))
                                        {
                                            <img class="rounded"
                                                 src="@item.Producto.UrlImagen"
                                                 width="50"
                                                 height="50"
                                                 style="object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-warning bg-opacity-10 rounded d-flex align-items-center justify-content-center"
                                                 style="width:40px;height:40px;">

                                                <span class="material-symbols-outlined text-warning">
                                                    inventory_2
                                                </span>

                                            </div>
                                        }

                                        <div>
                                            <p class="mb-0 small fw-bold text-light">
                                                @item.Producto?.Nombre
                                            </p>

                                            <p class="mb-0 text-secondary"
                                               style="font-size:10px;">
                                                @item.Producto?.Categoria
                                            </p>
                                        </div>

                                    </div>

                                    <div class="text-end">

                                        <p class="mb-0 small fw-black
                               @(item.Stock <= 2 ? "text-danger" : "text-warning")">

                                            @item.Stock uni.
                                        </p>

                                        <p class="mb-0 text-secondary"
                                           style="font-size:10px;">

                                            @(item.Stock <= 2 ? "Crítico" : "Bajo")

                                        </p>

                                    </div>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-success mb-0">
                                No existen productos con stock bajo.
                            </div>
                        }

                    </div>
                    <a asp-controller="Productos"
                       asp-action="Index"
                       class="btn btn-outline-secondary w-100 mt-4 text-uppercase fw-bold border-opacity-25"
                       style="font-size: 11px; letter-spacing: 1px;">

                        Gestionar Inventario

                    </a>
                </div>
                <!-- Recent Activity -->
                <div class="custom-card flex-grow-1">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="bg-primary rounded-pill" style="width: 4px; height: 24px;"></div>
                        <h2 class="h5 fw-bold mb-0 text-white">
                            Resumen Operativo
                        </h2>
                    </div>
                    <div class="timeline">

                        <div class="timeline-item">
                            <div class="timeline-dot bg-success"></div>

                            <p class="mb-0 small fw-bold text-light">
                                Facturas emitidas hoy
                            </p>

                            <p class="mb-1 text-secondary">
                                @Model.FacturasHoy facturas generadas
                            </p>

                            <span class="badge bg-success bg-opacity-10 text-success">
                                Facturación
                            </span>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot bg-primary"></div>

                            <p class="mb-0 small fw-bold text-light">
                                Envíos entregados hoy
                            </p>

                            <p class="mb-1 text-secondary">
                                @Model.EnviosEntregadosHoy entregas completadas
                            </p>

                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                Logística
                            </span>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot bg-danger"></div>

                            <p class="mb-0 small fw-bold text-light">
                                Pedidos cancelados
                            </p>

                            <p class="mb-1 text-secondary">
                                @Model.PedidosCancelados pedidos cancelados
                            </p>

                            <span class="badge bg-danger bg-opacity-10 text-danger">
                                Incidencias
                            </span>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Footer -->
    <footer class="mt-5 pt-4 border-top border-secondary border-opacity-10">
        <div class="row align-items-center">
            <div class="col-md-8 d-flex gap-5 mb-4 mb-md-0">
                <div>
                    <p class="text-uppercase fw-bold text-secondary mb-1" style="font-size: 10px; letter-spacing: 1px;">Servidor</p>
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-success rounded-circle" style="width: 8px; height: 8px;"></div>
                        <span class="small fw-bold text-secondary">Óptimo (99.9%)</span>
                    </div>
                </div>
                <div>
                    <p class="text-uppercase fw-bold text-secondary mb-1" style="font-size: 10px; letter-spacing: 1px;">Base de Datos</p>
                    <span class="small fw-bold text-secondary">Sincronizado</span>
                </div>
                <div>
                    <p class="text-uppercase fw-bold text-secondary mb-1" style="font-size: 10px; letter-spacing: 1px;">Versión</p>
                    <span class="small fw-bold text-secondary">v4.2.0-stable</span>
                </div>
            </div>
            <div class="col-md-4 text-md-end">
                <p class="text-secondary mb-0" style="font-size: 10px;">© 2024 SIMA Software Ecosystem. Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

</main>
