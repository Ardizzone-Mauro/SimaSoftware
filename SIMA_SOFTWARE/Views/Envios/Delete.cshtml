@model SIMA_SOFTWARE.Models.Envio

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<main class="main-content">

    <header class="mb-4">
        <h1 class="fw-black text-light">
            Eliminar Envío
        </h1>

        <p class="text-secondary">
            Confirmar eliminación
        </p>
    </header>

    <div class="custom-card p-4">

        <div class="alert alert-danger">
            ¿Seguro que querés eliminar este envío?
        </div>

        <table class="table table-dark">

            <tr>
                <th>ID</th>
                <td>#@Model.IdEnvio</td>
            </tr>

            <tr>
                <th>Pedido</th>
                <td>#@Model.IdPedido</td>
            </tr>

            <tr>
                <th>Fecha</th>
                <td>@Model.Fecha.ToString("dd/MM/yyyy")</td>
            </tr>

            <tr>
                <th>Estado</th>
                <td>@Model.Estado?.Descripcion</td>
            </tr>

        </table>

        <form asp-action="Delete">

            <input type="hidden" asp-for="IdEnvio" />

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-danger">
                    🗑 Eliminar
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    ← Volver
                </a>

            </div>

        </form>

    </div>

</main>