@model IEnumerable<SIMA_SOFTWARE.Models.Factura>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var totalFacturado = Model?.Sum(f => f.MontoTotal) ?? 0;
    var totalIVA = Model?.Sum(f => f.Impuestos) ?? 0;
    var cantidad = Model?.Count() ?? 0;
}

<main class="main-content">

    <h2 class="text-white mb-4">🧾 Facturación</h2>

    @if (TempData["mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["mensaje"]
        </div>
    }

    <a href="/Pedido/Index" class="btn btn-outline-light mb-3">
        ← Volver a pedidos
    </a>

    <!-- 🔍 FILTROS -->
    <form method="get" class="mb-4">
        <div class="row g-2">

            <!-- CLIENTE -->
            <div class="col-md-4">
                <select name="clienteId" class="form-control">
                    <option value="">Todos los clientes</option>

                    @foreach (var c in ViewBag.Clientes)
                    {
                        var selected = Context.Request.Query["clienteId"] == c.IdCliente.ToString();

                        <option value="@c.IdCliente" selected="@(selected)">
                            @c.Nombre
                        </option>
                    }
                </select>
            </div>

            <!-- FECHA DESDE -->
            <div class="col-md-3">
                <input type="date"
                       name="fechaDesde"
                       class="form-control"
                       value="@Context.Request.Query["fechaDesde"]" />
            </div>

            <!-- FECHA HASTA -->
            <div class="col-md-3">
                <input type="date"
                       name="fechaHasta"
                       class="form-control"
                       value="@Context.Request.Query["fechaHasta"]" />
            </div>

            <!-- BOTON -->
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    🔍 Filtrar
                </button>
            </div>

        </div>
    </form>

    <!-- 🔥 RESUMEN -->
    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <h6>Total Facturado</h6>
                    <h3>$ @totalFacturado.ToString("N2")</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <h6>Cantidad Facturas</h6>
                    <h3>@cantidad</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-warning text-dark shadow">
                <div class="card-body">
                    <h6>Total IVA</h6>
                    <h3>$ @totalIVA.ToString("N2")</h3>
                </div>
            </div>
        </div>

    </div>

    <!-- 🔥 TABLA -->
    <div class="card shadow-lg border-0">
        <div class="card-body">

            <div class="table-responsive">
                <table id="facturasTable" class="table table-dark table-hover align-middle text-white">

                    <thead>
                        <tr>
                            <th>N° Factura</th>
                            <th>Cliente</th>
                            <th>Fecha</th>
                            <th>Total</th>
                            <th>IVA</th>
                            <th>Tipo</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var f in Model)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        @($"{f.PuntoVenta}-{f.Numero.ToString("00000000")}")
                                    </td>

                                    <td>@f.Cliente?.Nombre</td>

                                    <td>@f.FechaEmision.ToString("dd/MM/yyyy")</td>

                                    <td class="text-success fw-bold">
                                        $ @f.MontoTotal.ToString("N2")
                                    </td>

                                    <td class="text-warning">
                                        $ @f.Impuestos.ToString("N2")
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @f.Tipo
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <a asp-action="Imprimir"
                                           asp-route-id="@f.IdFactura"
                                           class="btn btn-sm btn-outline-light">
                                            👁 Ver
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-secondary">
                                    No hay facturas registradas
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</main>

@section Scripts {
    <script src="~/js/datatables-facturacion.js"></script>
}