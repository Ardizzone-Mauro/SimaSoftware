@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- 🔽 SELECT2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<main class="main-content">

    <a href="/Pedido/Index" class="btn btn-outline-light mb-3">
        ← Volver a pedidos
    </a>

    <header class="mb-4">
        <h1 class="fw-black text-light">Nueva Venta</h1>
        <p class="text-secondary">Registrar pedido</p>
    </header>

    <p style="color:black;">Clientes cargados: @ViewBag.CantidadClientes</p>

    <div class="custom-card p-4">

        <!-- 🔍 CLIENTE -->
        <div class="mb-3">

            <label class="text-light">Tipo de cliente</label>
            <select id="tipoClienteFiltro" class="form-control mb-2">
                <option value="">Todos</option>
                <option value="Minorista">Minorista</option>
                <option value="Mayorista">Mayorista</option>
            </select>

            <label class="text-light">Cliente</label>
            <select class="form-control" id="clienteSelect">
                <option></option>
                @foreach (var c in ViewBag.Clientes)
                {
                    <option value="@c.IdCliente" data-tipo="@c.TipoCliente?.Categoria">
                        @c.Nombre (@c.TipoCliente?.Categoria)
                    </option>
                }
            </select>

        </div>

        <!-- 🔍 PRODUCTO -->
        <div class="row">
            <div class="col-md-6">
                <label class="text-light">Producto</label>
                <select class="form-control" id="productoSelect">
                    <option></option>
                    @foreach (var p in ViewBag.Productos)
                    {
                        <option value="@p.IdProducto" data-precio="@p.Precio">
                            @p.Nombre
                        </option>
                    }
                </select>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-3">
                    <label class="text-light">Cantidad</label>
                    <input type="number" min="1" class="form-control" id="cantidad" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-success w-100" onclick="agregarItem()">Agregar</button>
                </div>
            </div>
        </div>

        <!-- 📊 DETALLE -->
        <div class="table-responsive">
            <table class="table table-custom mt-4">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="detalle"></tbody>
            </table>
        </div>

        <!-- 💰 TOTAL -->
        <div class="text-end total-box">
            Total: $<span id="total">0</span>
        </div>

        <button class="btn btn-success w-100" onclick="guardarPedido()">
            💾 Guardar Pedido
        </button>
    </div>

</main>

@section Scripts {

    <script src="~/js/pedido.js"></script>

    <!-- 🔽 jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- 🔽 SELECT2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
               $(document).ready(function () {

            $('#clienteSelect').select2({
                placeholder: "Buscar cliente...",
                allowClear: true,
                width: '100%'
            });

            $('#productoSelect').select2({
                placeholder: "Buscar producto...",
                allowClear: true,
                width: '100%'
            });

            let clientesOriginales = [];

            $('#clienteSelect option').each(function () {
                if ($(this).val()) {
                    clientesOriginales.push({
                        id: $(this).val(),
                        text: $(this).text(),
                        tipo: $(this).data('tipo')
                    });
                }
            });

            $('#tipoClienteFiltro').on('change', function () {

                let tipo = $(this).val();

                let filtrados = clientesOriginales.filter(c =>
                    !tipo || c.tipo === tipo
                );

                $('#clienteSelect').empty().append('<option></option>');

                filtrados.forEach(c => {
                    $('#clienteSelect').append(
                        new Option(c.text, c.id)
                    );
                });

                $('#clienteSelect').val(null).trigger('change');
            });

        });
    </script>
}

<style>
    .select2-container--default .select2-selection--single {
        background-color: #000 !important;
        border: 1px solid #444 !important;
    }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: #fff !important;
        }

    .select2-container--default .select2-selection__arrow b {
        border-color: #fff transparent transparent transparent !important;
    }

    .select2-container--default .select2-dropdown {
        background-color: #000 !important;
        border: 1px solid #444 !important;
    }

    .select2-container--default .select2-results__option {
        color: #fff !important;
    }

    .select2-container--default .select2-results__option--highlighted {
        background-color: #0d6efd !important;
        color: #fff !important;
    }

    .select2-search__field {
        background-color: #000 !important;
        color: #fff !important;
        border: 1px solid #444 !important;
    }

    .select2-container--default .select2-selection--single .select2-selection__placeholder {
        color: #aaa !important;
    }
</style>