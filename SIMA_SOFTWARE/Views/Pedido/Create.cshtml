@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- 🔽 SELECT2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<main class="main-content">

    <header class="mb-4">
        <h1 class="fw-black text-light">Nueva Venta</h1>
        <p class="text-secondary">Registrar pedido</p>
    </header>

    <p style="color:black;">Clientes cargados: @ViewBag.CantidadClientes</p>

    <div class="custom-card p-4">

        <!-- 🔍 CLIENTE -->
        <div class="mb-3">
            <label class="text-light">Cliente</label>
            <select class="form-control" id="clienteSelect">
                <option></option>
                @foreach (var c in ViewBag.Clientes)
                {
                    <option value="@c.IdCliente">
                        @c.Nombre
                    </option>
                }
            </select>
        </div>

        <!-- 🔍 PRODUCTO -->
        <div class="row">
            <div class="col-md-6">
                <label class="text-light">Producto</label>
                <select class="form-control" id="productoSelect">
                    <option></option>
                    @foreach (var p in ViewBag.Productos)
                    {
                        <option value="@p.IdProducto" data-precio="@p.Precio">
                            @p.Nombre
                        </option>
                    }
                </select>
            </div>

            <div class="row g-3">
                <div class="col-md-3">
                    <label class="text-light">Cantidad</label>
                    <input type="number" class="form-control" id="cantidad" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-success w-100" onclick="agregarItem()">Agregar</button>
                </div>
            </div>
        </div>

        <!-- 📊 DETALLE -->
        <div class="table-responsive">
            <table class="table table-custom mt-4">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="detalle"></tbody>
            </table>
        </div>

        <!-- 💰 TOTAL -->
        <div class="text-end total-box">
            Total: $<span id="total">0</span>
        </div>

        <button class="btn btn-success w-100" onclick="guardarPedido()">
            💾 Guardar Pedido
        </button>
    </div>

</main>

<!-- 🔽 SCRIPTS -->
@section Scripts {

    <script src="~/js/pedido.js"></script>

    <!-- 🔽 jQuery (necesario para Select2) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- 🔽 SELECT2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {

            // 🔍 BUSCADOR CLIENTES
            $('#clienteSelect').select2({
                placeholder: "Buscar cliente...",
                allowClear: true,
                width: '100%'
            });

            // 🔍 BUSCADOR PRODUCTOS
            $('#productoSelect').select2({
                placeholder: "Buscar producto...",
                allowClear: true,
                width: '100%'
            });

        });
    </script>
}