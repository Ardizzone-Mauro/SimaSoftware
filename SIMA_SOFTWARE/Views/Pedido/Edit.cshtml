@model SIMA_SOFTWARE.Models.ViewModels.PedidoViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="text-white mb-4">Editar Pedido</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="IdPedido" />

    <!-- CLIENTE -->
    <div class="mb-3">
        <label class="text-light">Cliente</label>

        <select asp-for="IdCliente" asp-items="Model.Clientes" class="form-control">
        </select>
    </div>

    <!-- DETALLE -->
    <table class="table table-dark">
        <thead>
            <tr>
                <th>Producto</th>
                <th>Cantidad</th>
            </tr>
        </thead>

        <tbody>
            @for (int i = 0; i < Model.Detalles.Count; i++)
            {
                <tr>
                    <td>
                        @Model.Detalles[i].IdProducto
                        <input type="hidden" asp-for="Detalles[i].IdProducto" />
                    </td>
                    <td>
                        <input type="number"
                               asp-for="Detalles[i].Cantidad"
                               class="form-control" />
                        <input type="hidden" asp-for="Detalles[i].Precio" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-success w-100 mt-3">
        💾 Guardar Cambios
    </button>

</form>