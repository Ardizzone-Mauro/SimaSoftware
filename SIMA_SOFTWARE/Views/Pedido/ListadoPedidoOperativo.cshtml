@model List<SIMA_SOFTWARE.Models.ViewModels.PedidoListadoViewModel>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<main class="main-content">
    <div class="container-fluid p-0">

        <h1 class="page-title">Listado Operativo de Pedidos</h1>

        <!-- FILTROS -->
        <form method="get" class="row g-3 mb-4">

            <div class="col-md-3">
                <label class="text-light">Desde</label>
                <input type="date" name="desde" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="text-light">Hasta</label>
                <input type="date" name="hasta" class="form-control" />
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-success w-100">
                    Filtrar
                </button>
            </div>

        </form>
        <div class="mb-3">
            <a class="btn btn-primary"
               asp-controller="Pedido"
               asp-action="ExportarExcel"
               asp-route-desde="@Context.Request.Query["desde"]"
               asp-route-hasta="@Context.Request.Query["hasta"]">

                📥 Exportar Excel
            </a>
        </div>
        <!-- TABLA -->
        <div class="custom-card p-3">

            <table id="pedidosTable"
                   class="table table-dark table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Total</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.IdPedido</td>
                            <td>@p.Cliente</td>
                            <td>@p.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge bg-warning text-dark">
                                    @p.Estado
                                </span>
                            </td>
                            <td>$@p.Total.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>
    
</main>

@section Scripts {
    <script src="~/js/datatables-listadoPedido.js"></script>
}
