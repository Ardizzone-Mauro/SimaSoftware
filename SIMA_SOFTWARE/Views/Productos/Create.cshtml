@model SIMA_SOFTWARE.Models.ViewModels.ProductoViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<main class="main-content">
    <div class="container-fluid p-0">

        <!-- HEADER -->
        <div class="row align-items-end mb-5 gy-4">
            <div class="col-lg-8">
                <nav class="breadcrumb-text">
                    <span>Productos</span>
                    <span class="material-symbols-outlined" style="font-size: 12px;">chevron_right</span>
                    <span class="breadcrumb-active">Nuevo Producto</span>
                </nav>

                <h1 class="page-title">Crear Producto</h1>
                <p class="page-desc text-secondary">
                    Agregá un nuevo producto al catálogo con imagen, precio y descripción.
                </p>
            </div>

            <div class="col-lg-4 text-lg-end">
                <a asp-action="Index" class="btn btn-dark">
                    ← Volver
                </a>
            </div>
        </div>

        <!-- FORM -->
        <div class="custom-card p-4">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">

                    <!-- NOMBRE -->
                    <div class="col-md-12">
                        <label asp-for="Nombre" class="form-label text-light"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <!-- PRECIO -->
                    <div class="col-md-3">
                        <label asp-for="Precio" class="form-label text-light"></label>
                        <input asp-for="Precio" class="form-control" />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>

                    <!-- CATEGORIA -->
                    <div class="col-md-4">
                        <label asp-for="Categoria" class="form-label text-light"></label>
                        <select asp-for="Categoria" class="form-select">
                            <option value="LINEA RUECA">Linea Rueca</option>
                            <option value="LINEA TELAR">Linea Telar</option>
                        </select>
                    </div>

                    <!-- COLOR -->
                    <div class="col-md-4">
                        <label asp-for="Color" class="form-label text-light"></label>
                        <input asp-for="Color" class="form-control" />
                    </div>

                    <!-- HEBRAS -->
                    <div class="col-md-4">
                        <label asp-for="CantidadHebras" class="form-label text-light"></label>
                        <input asp-for="CantidadHebras" class="form-control" />
                    </div>

                    <!--DEPOSITO-->
                    <div class="col-md-3">
                        <label class="text-light">Depósito</label>
                        <select asp-for="IdDeposito" class="form-select" asp-items="ViewBag.Depositos"></select>
                    </div>

                    <!-- STOCK -->
                    <div class="col-md-3">
                        <label asp-for="StockInicial" class="form-label text-light"></label>
                        <input asp-for="StockInicial" class="form-control" />
                        <span asp-validation-for="StockInicial" class="text-danger"></span>
                    </div>

                    <!-- DESCRIPCIÓN -->
                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label text-light"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    </div>

                    <!-- IMAGEN / DROPZONE -->
                    <div class="col-md-8">
                        <label class="form-label text-light">Imagen del Producto</label>

                        <!-- INPUT REAL (OCULTO) -->
                        <input asp-for="Imagen"
                               type="file"
                               id="inputImagen"
                               class="d-none"
                               accept="image/*"
                               onchange="previewImagen(event)" />

                        <!-- UI VISUAL -->
                        <div onclick="document.getElementById('inputImagen').click()"
                             class="border-2 border-dashed rounded-4 p-4 text-center"
                             style="border-color:#1e293b; background:#020617; cursor:pointer; transition:0.3s;"
                             onmouseover="this.style.borderColor='#10b981'"
                             onmouseout="this.style.borderColor='#1e293b'">

                            <div class="mb-2">
                                <span class="material-symbols-outlined" style="font-size:40px; color:#64748b;">
                                    cloud_upload
                                </span>
                            </div>

                            <p class="mb-1" style="font-size:13px; font-weight:600; color:#cbd5f5;">
                                Hacé click para subir
                            </p>

                            <p style="font-size:11px; color:#64748b;">
                                PNG, JPG o WebP (Max. 5MB)
                            </p>
                        </div>

                        <!-- VALIDACIÓN -->
                        <span asp-validation-for="Imagen" class="text-danger"></span>
                    </div>

                    <!-- PREVIEW -->
                    <div class="col-md-4 text-center ">
                        <img id="preview"
                             src="/img/no-image.png"
                             style="max-width:200px; border-radius:12px; border:1px solid #1e293b;" />
                    </div>

                </div>

                <!-- BOTONES -->
                <div class="mt-4 d-flex gap-3">

                    <button type="submit" class="btn btn-success">
                        💾 Guardar Producto
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImagen(event) {
            const input = event.target;
            const preview = document.getElementById("preview");

            if (input.files && input.files[0]) {
                preview.src = URL.createObjectURL(input.files[0]);
            }
        }
    </script>
}