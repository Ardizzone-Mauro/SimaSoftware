@model List<SIMA_SOFTWARE.Models.ViewModels.UsuarioRolViewModel>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<main class="main-content">
    <div class="container-fluid p-0">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="text-white mb-1">Usuarios y Roles</h2>
                <p class="text-secondary mb-0">
                    Asigná roles a cada usuario del sistema
                </p>
            </div>
        </div>

        <div class="glass-card p-0 overflow-hidden">

            <div class="table-responsive">
                <table class="table table-custom align-middle mb-0">

                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Roles actuales</th>
                            <th>Asignar roles</th>
                            <th class="text-end">Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <form asp-action="AsignarRoles" method="post">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="userId" value="@user.UserId" />

                                    <!-- USUARIO -->
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-light">@user.NombreCompleto</span>
                                        <span class="text-secondary small">@user.Email</span>
                                    </div>
                                </td>

                                <!-- ROLES ACTUALES -->
                                <td>
                                    @foreach (var rol in user.RolesAsignados)
                                    {
                                        <span class="badge bg-success me-1">@rol</span>
                                    }
                                </td>

                                <!-- CHECKBOX -->
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var rol in user.TodosLosRoles)
                                        {
                                            var isChecked = user.RolesAsignados.Contains(rol.Value);

                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="rolesSeleccionados"
                                                       value="@rol.Value"
                                                       @(isChecked ? "checked" : "") />

                                                <label class="form-check-label text-light small">
                                                    @rol.Text
                                                </label>
                                            </div>
                                        }
                                    </div>
                                </td>

                                <!-- BOTÓN -->
                                <td class="text-end">
                                    <button type="submit" class="btn btn-success btn-sm" style="width:120px;">
                                        Guardar
                                    </button>
                                </td>

                                </form>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>

    </div>
</main>