@using Microsoft.AspNetCore.Identity
@inject SignInManager<SIMA_SOFTWARE.Models.ApplicationUser> SignInManager
@inject UserManager<SIMA_SOFTWARE.Models.ApplicationUser> UserManager


@{
}
<html>
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>SIMA Software - Panel de Control</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Manrope:wght@600;700;800&amp;display=swap" rel="stylesheet" />
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
   

    <!-- DataTables CSS (global) -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/productos.css" />
    @* <link rel="stylesheet" href="~/css/datatables-clientes.css" /> *@
</head>
<body>
    <!-- Top Navbar -->
    <nav class="top-navbar d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-4">
            <span class="fs-4 fw-black text-emerald font-headline text-success d-none d-lg-block" style="letter-spacing: -1px;">SIMA Software</span>
            <div class="search-container d-none d-md-flex">
                <span class="material-symbols-outlined text-secondary fs-6 me-2">search</span>
                <input class="search-input" placeholder="Buscar en SIMA..." type="text" />
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-link text-secondary p-2 rounded-circle hover-bg-dark">
                <span class="material-symbols-outlined">notifications</span>
            </button>
            <button class="btn btn-link text-secondary p-2 rounded-circle hover-bg-dark">
                <span class="material-symbols-outlined">settings</span>
            </button>
            <button class="btn btn-link text-secondary p-2 rounded-circle hover-bg-dark">
                <span class="material-symbols-outlined">help</span>
            </button>
            <div class="vr mx-2 bg-secondary opacity-25" style="height: 24px;"></div>
            <div class="d-flex align-items-center gap-2">

                <!-- Dropdown usuario -->
                <div class="dropdown">
                    <button class="btn btn-link dropdown-toggle d-flex align-items-center p-0"
                            data-bs-toggle="dropdown">

                        <img class="rounded-circle border border-2 border-secondary"
                             height="50"
                             width="50"
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuASQEu93ZUjOPhNYVLSCv8sJkJwbo5hAldXanHCVmGXtXgOEJQee5Nj8fiOY41AcqwB6FtdCkjnz4W64wgp4e69cTAnNIG64gIizRrwuag_wbnQNItNWMejbKPuTK2PEHbipZqjPC0irrFtUyQXCL06dwKw1ovhu9kBY-hl_c1mGZ76SQTwvdeqfs9uybe18jmCM0O4Vn7MmM-sl59egGZGvi2Tz4WhnKYl9aEag-LOJ12He4cVaBCZmYhF2N8OySBS_cRYNboyklLA" />
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <span class="dropdown-item-text fw-bold">
                                @User.Identity?.Name
                            </span>
                        </li>

                        <li>
                            @{
                                var user = await UserManager.GetUserAsync(User);
                                var roles = user != null
                                ? await UserManager.GetRolesAsync(user)
                                : new List<string>();
                            }

                            <div class="px-3 py-2 d-flex gap-1 flex-wrap">
                                @foreach (var role in roles)
                                {
                                    <span class="badge bg-success">@role</span>
                                }
                            </div>
                        </li>
                    </ul>
                </div>

                <!-- Logout -->
                <form asp-controller="Usuario"
                      asp-action="Logout"
                      method="post"
                      class="d-flex align-items-center m-0">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="btn btn-link text-secondary p-2 rounded-circle hover-bg-dark d-flex align-items-center justify-content-center"
                            title="Cerrar sesión">

                        <span class="material-symbols-outlined">
                            logout
                        </span>
                    </button>
                </form>

            </div>
        </div>
               
    </nav>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <!-- Sidebar -->
    <aside class="sidebar">

        <div class="px-4 mb-3">
            <p class="text-uppercase small fw-bold text-secondary tracking-widest mb-0"
               style="font-size: 10px;">
                Menú Principal
            </p>
        </div>

        <nav class="nav flex-column">

            <!-- DASHBOARD -->
            <a class="nav-link @(currentController == "Dashboard" ? "active" : "")"
               asp-controller="Dashboard"
               asp-action="Index">

                <span class="material-symbols-outlined">dashboard</span>
                Dashboard
            </a>

            <!-- CLIENTES -->
            <a class="nav-link @(currentController == "Clientes" ? "active" : "")"
               asp-controller="Clientes"
               asp-action="Index">

                <span class="material-symbols-outlined">group</span>
                Clientes
            </a>

            <!-- PRODUCTOS -->
            <a class="nav-link @(currentController == "Productos" ? "active" : "")"
               asp-controller="Productos"
               asp-action="Index">

                <span class="material-symbols-outlined">inventory_2</span>
                Productos
            </a>

            <!-- PEDIDOS -->
            <a class="nav-link @(currentController == "Pedido" && currentAction == "Index" ? "active" : "")"
               asp-controller="Pedido"
               asp-action="Index">

                <span class="material-symbols-outlined">shopping_cart</span>
                Pedidos
            </a>

            <!-- FACTURACION -->
            <a class="nav-link @(currentController == "Facturacion" ? "active" : "")"
               asp-controller="Facturacion"
               asp-action="Index">

                <span class="material-symbols-outlined">receipt_long</span>
                Facturación
            </a>

            <!-- ENVIOS -->
            <a class="nav-link @(currentController == "Envios" ? "active" : "")"
               asp-controller="Envios"
               asp-action="Index">

                <span class="material-symbols-outlined">local_shipping</span>
                Envíos
            </a>

            <!-- REPORTES -->
            <div class="mt-3 px-3 text-uppercase text-secondary fw-bold"
                 style="font-size: 11px; letter-spacing: 1px;">
                Reportes
            </div>

            <!-- LISTADO OPERATIVO -->
            <a class="nav-link @(currentAction == "ListadoPedidoOperativo" ? "active" : "")"
               asp-controller="Pedido"
               asp-action="ListadoPedidoOperativo">

                <span class="material-symbols-outlined">list_alt</span>
                Listado de Pedidos
            </a>

            <!-- INFORME GERENCIAL -->
            <a class="nav-link @(currentController == "Reportes" ? "active" : "")"
               asp-controller="Reportes"
               asp-action="VentasMensuales">

                <span class="material-symbols-outlined">analytics</span>
                Informe Gerencial
            </a>

            <!-- NOTIFICACIONES -->
            <a class="nav-link @(currentController == "Notificaciones" ? "active" : "")"
               asp-controller="Notificaciones"
               asp-action="Index">

                <span class="material-symbols-outlined">notifications</span>
                Notificaciones
            </a>

        </nav>

        <!-- BOTON -->
        <div class="px-4 mt-5">

            <a asp-controller="Pedido"
               asp-action="Create"
               class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2">

                <span class="material-symbols-outlined fs-5">add</span>
                Nuevo Pedido
            </a>

        </div>

    </aside>



    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Scripts globales -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables JS (global) -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

    @* <!-- Script de inicialización específico para clientes -->
    <script src="~/js/datatables-clientes.js"></script> *@

    @RenderSection("Scripts", required: false)
</body>
</html>

