@{
    // ViewData["Title"] = "Iniciar sesion";
    Layout = "_AuthLayout";
}
@using SIMA_SOFTWARE.Models.ViewModels

@model LoginViewModel;


<div class="bg-pattern"></div>

<div class="login-layout">

    <!-- LADO IZQUIERDO -->
    <div class="branding-side">

        <div class="branding-content">

            <!-- LOGO -->
            <div class="branding-logo">

                <img src="~/images/Logo_Sima_Software.png"
                     alt="SIMA Software Logo"
                     class="logo-image" />

            </div>

        </div>

    </div>

    <!-- LADO DERECHO -->
    <div class="form-side">

        <div class="auth-card">

            <div class="text-center mb-4">

                <h2 class="text-white fw-bold">
                    Bienvenido
                </h2>

                <p class="text-secondary mb-0">
                    Iniciar sesión en el sistema
                </p>

            </div>

            <!-- ERRORES -->
            <div asp-validation-summary="ModelOnly"
                 class="text-danger small mb-3">
            </div>

            <form method="post" autocomplete="on">

                <input type="hidden"
                       name="returnUrl"
                       value="@ViewData["ReturnUrl"]" />

                <!-- EMAIL -->
                <div class="mb-3">

                    <label asp-for="Email"
                           class="form-label">
                    </label>

                    <input asp-for="Email"
                           type="email"
                           class="form-control"
                           placeholder="usuario@sima.com"
                           autocomplete="email" />

                    <span asp-validation-for="Email"
                          class="text-danger small">
                    </span>

                </div>

                <!-- PASSWORD -->
                <div class="mb-3">

                    <label asp-for="Clave"
                           class="form-label">
                    </label>

                    <input asp-for="Clave"
                           type="password"
                           class="form-control"
                           placeholder="••••••••"
                           autocomplete="new-password" />

                    <span asp-validation-for="Clave"
                          class="text-danger small">
                    </span>

                </div>

                <!-- RECORDARME -->
                <div class="mb-4 d-flex justify-content-between align-items-center">

                    <div class="form-check">

                        <input asp-for="Recordarme"
                               class="form-check-input" />

                        <label asp-for="Recordarme"
                               class="form-check-label text-light small">
                        </label>

                    </div>

                    <a class="forgot-password"
                       href="/Usuario/RecuperarCuenta">

                        ¿Olvidó su contraseña?

                    </a>

                </div>

                <!-- BOTÓN LOGIN -->
                <button class="btn btn-primary w-100 py-2"
                        type="submit">

                    Acceder al Sistema

                </button>

            </form>

            <!-- REGISTRO -->
            <div class="mt-4 pt-4 border-top border-secondary border-opacity-25 text-center">

                <p class="text-secondary small mb-3">
                    ¿No tienes una cuenta?
                </p>

                <a asp-controller="Usuario"
                   asp-action="Registro"
                   class="btn btn-outline-light w-100">

                    <i class="bi bi-person-plus me-2"></i>

                    Crear cuenta

                </a>

            </div>

        </div>

    </div>

</div>



